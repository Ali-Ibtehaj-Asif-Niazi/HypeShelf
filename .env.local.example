# ─── Clerk ────────────────────────────────────────────────────────────────────
# Found in: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect paths after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/recs
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/recs

# ─── Convex ────────────────────────────────────────────────────────────────────
# Found in: Convex Dashboard → Settings, or printed by `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=https://YOUR_CONVEX_DEPLOYMENT.convex.cloud

# ─── Clerk → Convex JWT Domain ─────────────────────────────────────────────────
# Found in: Clerk Dashboard → JWT Templates → convex → Issuer field
# Example: https://clerk.your-domain.dev  OR  https://YOUR_INSTANCE.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev
